{
  "name": "zerollama",
  "version": "1.0.0",
  "description": "Zerollama – local network middleware proxy for Ollama",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md,yml,yaml}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md,yml,yaml}\" \".github/workflows/*.yml\""
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@types/blessed": "^0.1.27",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
